{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernel-foundry.local/schemas/research-state.schema.json",
  "title": "Bounded autonomous kernel research state",
  "type": "object",
  "required": ["schema_version", "project", "mode", "contract", "status", "budgets", "objectives", "hypotheses", "experiments", "pareto_frontier"],
  "properties": {
    "schema_version": {"type": "integer", "minimum": 1},
    "project": {"type": "string", "minLength": 1},
    "mode": {"enum": ["quick", "standard", "research"]},
    "contract": {"type": "string", "minLength": 1},
    "status": {"enum": ["active", "complete", "blocked"]},
    "budgets": {
      "type": "object",
      "required": ["max_experiments", "max_tpu_hours", "max_failures"],
      "properties": {
        "max_experiments": {"type": "integer", "minimum": 1},
        "max_tpu_hours": {"type": "number", "minimum": 0},
        "max_failures": {"type": "integer", "minimum": 1}
      }
    },
    "objectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "direction"],
        "properties": {"name": {"type": "string"}, "direction": {"enum": ["min", "max"]}}
      }
    },
    "hypotheses": {"type": "array"},
    "experiments": {"type": "array"},
    "pareto_frontier": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
