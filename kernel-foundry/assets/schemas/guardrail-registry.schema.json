{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernel-foundry.local/schemas/guardrail-registry.schema.json",
  "title": "Kernel guardrail registry",
  "type": "object",
  "required": ["schema_version", "guardrails"],
  "properties": {
    "schema_version": {"type": "integer", "minimum": 1},
    "updated_at": {"type": "string"},
    "guardrails": {"type": "array", "items": {"$ref": "#/$defs/guardrail"}}
  },
  "$defs": {
    "condition": {
      "type": "object",
      "required": ["path", "op"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "op": {"enum": ["eq", "ne", "lt", "le", "gt", "ge", "exists", "truthy", "contains", "in"]},
        "value": {},
        "other_path": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "guardrail": {
      "type": "object",
      "required": ["id", "description", "scope", "when", "assertions", "action"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "scope": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "when": {"type": "array", "items": {"$ref": "#/$defs/condition"}},
        "assertions": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/condition"}},
        "action": {"type": ["string", "object"]},
        "source_failure": {"type": "string"},
        "compiled_at": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
